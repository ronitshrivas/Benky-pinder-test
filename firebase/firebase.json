{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs22",
    "predeploy": [
      "npm --prefix \"$RESOURCE_DIR\" run build"
    ]
  },
  "apphosting": [
    {
      "backendId": "becky-pinder-yoga-web",
      "rootDir": "..",
      "ignore": [
        "node_modules",
        ".next",
        ".git",
        ".env*",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "firebase/functions"
      ]
    }
  ]
}
