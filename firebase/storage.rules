rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Gallery images — public read, admin upload
    match /gallery/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Course thumbnails — public read, admin upload
    match /courses/thumbnails/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Course videos — authenticated read (must have purchased), admin upload
    match /courses/videos/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Retreat images — public read, admin upload
    match /retreats/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Blog images — public read, admin upload
    match /blog/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // User profile photos — user can upload own, public read
    match /users/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
